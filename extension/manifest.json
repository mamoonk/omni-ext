{
  "manifest_version": 3,
  "name": "Omni-Ext Roblox Studio Agent",
  "version": "0.2.0",
  "description": "Turn free AI chats into a Roblox Studio agent via network interception + local bridge.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://gemini.google.com/*",
    "https://www.kimi.com/*",
    "https://chat.z.ai/*",
    "https://chat.qwen.ai/*",
    "https://arena.ai/*",
    "http://127.0.0.1/*",
    "ws://127.0.0.1/*"
  ],
  "background": { "service_worker": "background.js" },
  "icons": { "16": "icon.png", "48": "icon.png", "128": "icon.png" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Omni-Ext",
    "default_icon": { "16": "icon.png", "48": "icon.png", "128": "icon.png" }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://gemini.google.com/*",
        "https://www.kimi.com/*",
        "https://chat.z.ai/*",
        "https://chat.qwen.ai/*",
        "https://arena.ai/*"
      ],
      "js": ["core/net-intercept.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["core/config.js","core/parser.js","providers/deepseek.js","core/main.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["core/config.js","core/parser.js","providers/gemini.js","core/main.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.kimi.com/*"],
      "js": ["core/config.js","core/parser.js","providers/kimi.js","core/main.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.z.ai/*"],
      "js": ["core/config.js","core/parser.js","providers/glm.js","core/main.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://arena.ai/*"],
      "js": ["core/config.js","core/parser.js","providers/arena.js","core/main.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chat.qwen.ai/*"],
      "js": ["core/config.js","core/parser.js","providers/qwen.js","core/main.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
